# 机器配置模板
# 复制为 .env.machines 并填入实际值
# 不要将 .env.machines 提交到 git

# 格式：MACHINE_<machine-id>_<KEY>=<VALUE>
# 支持的 KEY：HOST, PORT, USER, KEY

# 本地共享目录会被远程 VM 通过 sshfs 挂载，因此需要提供本机 SSH 入口
SEED_RUNNER_LOCAL_HOST=10.162.158.95
SEED_RUNNER_LOCAL_SSH_PORT=22

# 可选：远程回连本机时使用的本地用户名，默认当前本地用户
# SEED_RUNNER_LOCAL_USER=ely

# 可选：远程回连本机时使用的私钥路径
# 默认尝试 ~/.ssh/<MACHINE_*_KEY 的文件名>
# SEED_RUNNER_REMOTE_TO_LOCAL_KEY=~/.ssh/id_ed25519

# 示例：SEED 实验 VM
MACHINE_vm-seed-01_HOST=192.168.1.100
MACHINE_vm-seed-01_PORT=22
MACHINE_vm-seed-01_USER=ubuntu
# 例如：~/.ssh/id_ed25519
MACHINE_vm-seed-01_KEY=/path/to/private/key

# 可以添加更多机器配置
# MACHINE_vm-seed-02_HOST=192.168.1.101
# MACHINE_vm-seed-02_PORT=22
# MACHINE_vm-seed-02_USER=ubuntu
# MACHINE_vm-seed-02_KEY=/path/to/private/key
